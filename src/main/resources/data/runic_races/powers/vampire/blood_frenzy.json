{
  "type": "origins:multiple",
  "name": "power.runic_races.vampire.blood_frenzy.name",
  "description": "power.runic_races.vampire.blood_frenzy.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "frenzy_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1800,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:vampire/blood_frenzy_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:vampire/blood_frenzy_cooldown_timer",
        "change": -1
      }
    }
  },
  "frenzy_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:vampire/blood_frenzy_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.5
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:strength",
              "duration": 120,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:regeneration",
              "duration": 120,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:vampire/blood_frenzy_cooldown_timer",
            "change": 1800
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Blood frenzy consumes you!\",\"color\":\"dark_red\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.warden.heartbeat",
            "volume": 0.8,
            "pitch": 1.5
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.warden.angry",
            "volume": 0.3,
            "pitch": 2.0
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:damage_indicator",
            "count": 15,
            "speed": 0.3,
            "spread": {
              "x": 0.5,
              "y": 1.0,
              "z": 0.5
            }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 0.8 0.0 0.0 1.0 ~ ~1 ~ 1.0 1.5 1.0 0.3 20 force"
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 0.2 0.0 0.0 1.2 ~ ~1 ~ 1.5 2.0 1.5 0.2 10 force"
          }
        ]
      }
    }
  }
}
