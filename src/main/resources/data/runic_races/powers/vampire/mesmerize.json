{
  "type": "origins:multiple",
  "name": "power.runic_races.vampire.mesmerize.name",
  "description": "power.runic_races.vampire.mesmerize.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:vampire/mesmerize_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:vampire/mesmerize_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:vampire/mesmerize_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 8,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:apply_effect",
                  "effect": {
                    "effect": "minecraft:weakness",
                    "duration": 200,
                    "amplifier": 1,
                    "is_ambient": false,
                    "show_particles": true,
                    "show_icon": true
                  }
                },
                {
                  "type": "origins:apply_effect",
                  "effect": {
                    "effect": "minecraft:slowness",
                    "duration": 200,
                    "amplifier": 2,
                    "is_ambient": false,
                    "show_particles": true,
                    "show_icon": true
                  }
                }
              ]
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:living"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:vampire/mesmerize_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your gaze mesmerizes the weak-willed...\",\"color\":\"dark_purple\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.warden.agitated",
          "volume": 0.6,
          "pitch": 2.0
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:ambient.cave",
          "volume": 0.3,
          "pitch": 1.5
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:sculk_soul",
          "count": 30,
          "speed": 0.3,
          "spread": { "x": 5.0, "y": 2.0, "z": 5.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.4, "y": 0.0, "z": 0.5 },
            "scale": 0.7
          },
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 2.0, "y": 1.0, "z": 2.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:enchanted_hit",
          "count": 8,
          "speed": 0.2,
          "spread": { "x": 3.0, "y": 1.5, "z": 3.0 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:sculk_soul ~ ~0.5 ~ 5.0 0.5 5.0 0.05 50 force"
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.35 0.0 0.5 0.5 ~ ~1 ~ 6.0 0.3 6.0 0.01 40 force"
        }
      ]
    }
  }
}
