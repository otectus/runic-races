{
  "type": "origins:multiple",
  "name": "power.runic_races.halfling.lightfoot.name",
  "description": "power.runic_races.halfling.lightfoot.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activate_stealth"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1800,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 3
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:halfling/lightfoot_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:halfling/lightfoot_cooldown_timer",
        "change": -1
      }
    }
  },

  "activate_stealth": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "cooldown": 0,
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:halfling/lightfoot_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 100,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:halfling/lightfoot_cooldown_timer",
          "change": 1800
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You slip into the shadows...\",\"color\":\"dark_gray\",\"italic\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.phantom.flap",
          "volume": 0.4,
          "pitch": 2.0
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.illusioner.prepare_blindness",
          "volume": 0.3,
          "pitch": 1.5
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:large_smoke",
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 0.5, "y": 0.5, "z": 0.5 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.8, "y": 0.8, "z": 0.8 },
            "scale": 0.4
          },
          "count": 15,
          "speed": 0.2,
          "spread": { "x": 0.6, "y": 0.6, "z": 0.6 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:large_smoke ~ ~0.5 ~ 0.8 0.3 0.8 0.02 25 force"
        }
      ]
    }
  }
}
