{
  "type": "origins:multiple",
  "name": "power.runic_races.halfling.lightfoot.name",
  "description": "power.runic_races.halfling.lightfoot.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activate_stealth"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 3
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:halfling/lightfoot_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:halfling/lightfoot_cooldown_timer",
        "change": -1
      }
    }
  },
  "activate_stealth": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "cooldown": 0,
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:halfling/lightfoot_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:halfling/lightfoot_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Light as a feather, quick as a fox!\",\"color\":\"gold\",\"italic\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.wool.step",
          "volume": 0.6,
          "pitch": 1.6
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.item.pickup",
          "volume": 0.3,
          "pitch": 1.9
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 1.0 0.85 0.35 0.6 ~ ~1 ~ 0.4 0.5 0.4 0.15 18 force"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:end_rod",
          "count": 12,
          "speed": 0.05,
          "spread": {
            "x": 0.3,
            "y": 0.4,
            "z": 0.3
          }
        }
      ]
    }
  }
}
