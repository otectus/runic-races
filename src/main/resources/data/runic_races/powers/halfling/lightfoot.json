{
  "type": "origins:multiple",
  "name": "power.runic_races.halfling.lightfoot.name",
  "description": "power.runic_races.halfling.lightfoot.description",
  "subpowers": [
    "cooldown_timer",
    "activate_stealth",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1800,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 3
    },
    "min_action": null,
    "max_action": null
  },

  "activate_stealth": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "cooldown": 0,
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:halfling/lightfoot_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 100,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:halfling/lightfoot_cooldown_timer",
          "change": 1800
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You slip into the shadows...\",\"color\":\"dark_gray\",\"italic\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:smoke",
          "count": 15,
          "speed": 0.1,
          "spread": {
            "x": 0.5,
            "y": 1.0,
            "z": 0.5
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
