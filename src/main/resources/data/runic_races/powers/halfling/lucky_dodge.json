            "spread": {
              "x": 0.5,
              "y": 0.5,
              "z": 0.5
            }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 0.3 1.0 0.3 0.6 ~ ~1 ~ 0.4 0.8 0.4 0.3 12 force"
          }
        ]
