{
  "type": "origins:multiple",
  "name": "power.runic_races.serpentfolk.shed_skin.name",
  "description": "power.runic_races.serpentfolk.shed_skin.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 3600,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
        "change": -1
      }
    }
  },
  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "runic_races:clear_effects_by_category",
          "category": "harmful"
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 60,
            "amplifier": 4,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
          "change": 3600
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You shed your skin!\",\"color\":\"green\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.horse.saddle",
          "volume": 0.7,
          "pitch": 0.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.wool.break",
          "volume": 0.4,
          "pitch": 0.6
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:item minecraft:leather ~ ~1 ~ 0.5 1.0 0.5 0.3 20 force"
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.7 0.9 0.6 0.7 ~ ~1 ~ 0.8 1.5 0.8 0.2 25 force"
        }
      ]
