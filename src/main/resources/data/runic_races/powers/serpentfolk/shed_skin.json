{
  "type": "origins:multiple",
  "name": "power.runic_races.serpentfolk.shed_skin.name",
  "description": "power.runic_races.serpentfolk.shed_skin.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 3600,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:poison"
        },
        {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:wither"
        },
        {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:weakness"
        },
        {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:slowness"
        },
        {
          "type": "origins:execute_command",
          "command": "effect clear @s minecraft:mining_fatigue"
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 60,
            "amplifier": 4,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:serpentfolk/shed_skin_cooldown_timer",
          "change": 3600
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You shed your skin!\",\"color\":\"green\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:item",
            "item": {
              "id": "minecraft:leather",
              "count": 1
            }
          },
          "count": 20,
          "speed": 0.3,
          "spread": {
            "x": 1.0,
            "y": 1.5,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to shed your skin, removing Poison, Wither, Weakness, Slowness, and Mining Fatigue. Grants Resistance V for 3 seconds. 180-second cooldown."
  }
}