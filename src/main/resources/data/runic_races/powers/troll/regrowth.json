{
  "type": "origins:multiple",
  "name": "power.runic_races.troll.regrowth.name",
  "description": "power.runic_races.troll.regrowth.description",
  "subpowers": [
    "upgrade_cooldown",
    "cooldown_decay",
    "passive_regen",
    "critical_regen",
    "badge"
  ],

  "upgrade_cooldown": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:troll/regrowth_upgrade_cooldown",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:troll/regrowth_upgrade_cooldown",
        "change": -1
      }
    }
  },

  "passive_regen": {
    "type": "origins:action_over_time",
    "interval": 30,
    "entity_action": {
      "type": "origins:apply_effect",
      "effect": {
        "effect": "minecraft:regeneration",
        "duration": 60,
        "amplifier": 0,
        "is_ambient": true,
        "show_particles": false,
        "show_icon": true
      }
    }
  },

  "critical_regen": {
    "type": "origins:action_over_time",
    "interval": 20,
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:health",
          "comparison": "<=",
          "compare_to": 0.25
        },
        {
          "type": "origins:resource",
          "resource": "runic_races:troll/regrowth_upgrade_cooldown",
          "comparison": "==",
          "compare_to": 0
        }
      ]
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:regeneration",
            "duration": 160,
            "amplifier": 2,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:troll/regrowth_upgrade_cooldown",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your wounds close with terrifying speed!\",\"color\":\"dark_red\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:heart",
          "count": 15,
          "speed": 0.3,
          "spread": {
            "x": 1.0,
            "y": 1.5,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Permanent Regeneration I. Below 25%% HP, upgrades to Regeneration III for 8 seconds. 120-second cooldown on the upgrade."
  }
}