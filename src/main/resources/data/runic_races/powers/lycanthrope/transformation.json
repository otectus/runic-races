{
  "type": "origins:multiple",
  "name": "power.runic_races.lycanthrope.transformation.name",
  "description": "power.runic_races.lycanthrope.transformation.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "beast_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:lycanthrope/transformation_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:lycanthrope/transformation_cooldown_timer",
        "change": -1
      }
    }
  },
  "beast_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:lycanthrope/transformation_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.3
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:strength",
              "duration": 600,
              "amplifier": 2,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:speed",
              "duration": 600,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:resistance",
              "duration": 600,
              "amplifier": 0,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:mining_fatigue",
              "duration": 600,
              "amplifier": 2,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:lycanthrope/transformation_cooldown_timer",
            "change": 1200
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"The beast within erupts!\",\"color\":\"red\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.wolf.growl",
            "volume": 1.0,
            "pitch": 0.5
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.wolf.howl",
            "volume": 0.8,
            "pitch": 0.7
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.warden.emerge",
            "volume": 0.3,
            "pitch": 1.5
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:angry_villager",
            "count": 20,
            "speed": 0.3,
            "spread": {
              "x": 1.0,
              "y": 1.0,
              "z": 1.0
            }
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:smoke",
            "count": 40,
            "speed": 0.5,
            "spread": {
              "x": 2.0,
              "y": 2.0,
              "z": 2.0
            }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 0.6 0.4 0.1 1.0 ~ ~1 ~ 2.0 2.0 2.0 0.3 25 force"
          }
        ]
      }
    }
  }
}
