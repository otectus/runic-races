{
  "type": "origins:multiple",
  "name": "power.runic_races.lycanthrope.howl_of_the_hunt.name",
  "description": "power.runic_races.lycanthrope.howl_of_the_hunt.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:lycanthrope/howl_of_the_hunt_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:lycanthrope/howl_of_the_hunt_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:lycanthrope/howl_of_the_hunt_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 16,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:strength",
                "duration": 200,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": true,
                "show_icon": true
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:entity_type",
              "entity_type": "minecraft:player"
            }
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:strength",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:lycanthrope/howl_of_the_hunt_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You howl, rallying the hunt!\",\"color\":\"gold\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:note",
          "count": 15,
          "speed": 0.5,
          "spread": {
            "x": 3.0,
            "y": 2.0,
            "z": 3.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to howl. Allies within 16 blocks and yourself gain Strength I for 10 seconds. 120-second cooldown."
  }
}