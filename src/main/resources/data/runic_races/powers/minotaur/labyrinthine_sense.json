{
  "type": "origins:multiple",
  "name": "power.runic_races.minotaur.labyrinthine_sense.name",
  "description": "power.runic_races.minotaur.labyrinthine_sense.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 6000,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:minotaur/labyrinthine_sense_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:minotaur/labyrinthine_sense_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:minotaur/labyrinthine_sense_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:night_vision",
            "duration": 300,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:area_of_effect",
          "radius": 30,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:glowing",
                "duration": 300,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": false,
                "show_icon": false
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:living"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:minotaur/labyrinthine_sense_cooldown_timer",
          "change": 6000
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your labyrinthine instincts awaken!\",\"color\":\"aqua\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.warden.sonic_boom",
          "volume": 0.3,
          "pitch": 2.0
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.ravager.stunned",
          "volume": 0.5,
          "pitch": 2.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:sonic_boom",
          "count": 5,
          "speed": 0.2,
          "spread": { "x": 3.0, "y": 1.0, "z": 3.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.2, "y": 0.8, "z": 0.8 },
            "scale": 0.6
          },
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 3.0, "y": 1.5, "z": 3.0 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.2 0.85 0.85 0.7 ~ ~1 ~ 5.0 0.3 5.0 0.01 60 force"
        }
      ]
    }
  }
}