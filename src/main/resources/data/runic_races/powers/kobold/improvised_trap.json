{
  "type": "origins:multiple",
  "name": "power.runic_races.kobold.improvised_trap.name",
  "description": "power.runic_races.kobold.improvised_trap.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
        "change": -1
      }
    }
  },
  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "runic_races:place_trap",
          "duration_ticks": 6000
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You set an improvised trap!\",\"color\":\"red\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.tripwire.attach",
          "volume": 0.6,
          "pitch": 1.4
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.wood.place",
          "volume": 0.5,
          "pitch": 0.7
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:smoke",
          "count": 12,
          "speed": 0.1,
          "spread": {
            "x": 0.4,
            "y": 0.2,
            "z": 0.4
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.8 0.4 0.1 0.7 ~ ~1 ~ 0.3 0.2 0.3 0.1 10 force"
        }
      ]
    }
  }
}
