{
  "type": "origins:multiple",
  "name": "power.runic_races.kobold.improvised_trap.name",
  "description": "power.runic_races.kobold.improvised_trap.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
        "change": -1
      }
    }
  },

  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 3,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:apply_effect",
                  "effect": {
                    "effect": "minecraft:slowness",
                    "duration": 80,
                    "amplifier": 2,
                    "is_ambient": false,
                    "show_particles": true,
                    "show_icon": true
                  }
                },
                {
                  "type": "origins:damage",
                  "amount": 3.0,
                  "source": {
                    "name": "mob",
                    "bypasses_armor": false
                  }
                }
              ]
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:living"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:kobold/improvised_trap_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You spring your trap!\",\"color\":\"red\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:smoke",
          "count": 20,
          "speed": 0.4,
          "spread": {
            "x": 2.0,
            "y": 1.0,
            "z": 2.0
          }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:flame",
          "count": 10,
          "speed": 0.3,
          "spread": {
            "x": 2.0,
            "y": 0.5,
            "z": 2.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to spring a trap: deal 3 damage and apply Slowness III for 4 seconds to entities within 3 blocks. 60-second cooldown."
  }
}