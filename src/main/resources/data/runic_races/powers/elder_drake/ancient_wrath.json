{
  "type": "origins:multiple",
  "name": "power.runic_races.elder_drake.ancient_wrath.name",
  "description": "power.runic_races.elder_drake.ancient_wrath.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "wrath_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
        "change": -1
      }
    }
  },

  "wrath_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:strength",
            "duration": 200,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Ancient wrath awakens!\",\"color\":\"dark_red\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:dragon_breath",
          "count": 25,
          "speed": 0.4,
          "spread": {
            "x": 2.0,
            "y": 1.5,
            "z": 2.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit, gain Strength II for 10 seconds (+25%% damage). 60-second cooldown. Ancient rage fuels your strikes."
  }
}