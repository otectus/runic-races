{
  "type": "origins:multiple",
  "name": "power.runic_races.elder_drake.ancient_wrath.name",
  "description": "power.runic_races.elder_drake.ancient_wrath.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "wrath_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
        "change": -1
      }
    }
  },
  "wrath_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:strength",
            "duration": 200,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:elder_drake/ancient_wrath_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Ancient wrath awakens!\",\"color\":\"dark_red\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.blaze.hurt",
          "volume": 0.7,
          "pitch": 0.6
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.ender_dragon.hurt",
          "volume": 0.3,
          "pitch": 0.8
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:dragon_breath",
          "count": 20,
          "speed": 0.5,
          "spread": {
            "x": 1.0,
            "y": 1.0,
            "z": 1.0
          }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:lava",
          "count": 8,
          "speed": 0.1,
          "spread": {
            "x": 0.8,
            "y": 0.5,
            "z": 0.8
          }
        }
      ]
    }
  }
}
