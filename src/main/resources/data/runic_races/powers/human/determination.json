{
  "type": "origins:multiple",
  "name": "power.runic_races.human.determination.name",
  "description": "power.runic_races.human.determination.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "health_check_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:human/determination_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:human/determination_cooldown_timer",
        "change": -1
      }
    }
  },

  "health_check_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:human/determination_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.3
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:absorption",
              "duration": 120,
              "amplifier": 2,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:regeneration",
              "duration": 120,
              "amplifier": 0,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:human/determination_cooldown_timer",
            "change": 2400
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Your determination surges!\",\"color\":\"gold\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.player.levelup",
            "volume": 0.8,
            "pitch": 1.5
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:item.totem.use",
            "volume": 0.4,
            "pitch": 1.5
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:totem_of_undying",
            "count": 20,
            "speed": 0.5,
            "spread": { "x": 0.5, "y": 1.5, "z": 0.5 }
          },
          {
            "type": "origins:spawn_particles",
            "particle": {
              "type": "minecraft:dust",
              "color": { "x": 0.95, "y": 0.85, "z": 0.3 },
              "scale": 1.0
            },
            "count": 15,
            "speed": 0.2,
            "spread": { "x": 0.5, "y": 1.0, "z": 0.5 }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 1.0 0.85 0.2 1.2 ~ ~1 ~ 0.3 2.0 0.3 0.05 30 force"
          }
        ]
      }
    }
  }
}
