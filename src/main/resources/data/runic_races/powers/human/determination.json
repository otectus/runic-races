{
  "type": "origins:multiple",
  "name": "power.runic_races.human.determination.name",
  "description": "power.runic_races.human.determination.description",
  "subpowers": [
    "cooldown_timer",
    "health_check_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "health_check_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:human/determination_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:health",
            "comparison": "<=",
            "compare_to": 0.2,
            "comparison_type": "percentage"
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:absorption",
              "duration": 80,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:human/determination_cooldown_timer",
            "change": 2400
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Your determination surges!\",\"color\":\"gold\",\"bold\":true}"
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:totem_of_undying",
            "count": 20,
            "speed": 0.5,
            "spread": {
              "x": 1.0,
              "y": 1.5,
              "z": 1.0
            }
          }
        ]
      }
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Triggered when reduced below 20%% HP. Grants Absorption II for 4 seconds. 120-second cooldown."
  }
}
