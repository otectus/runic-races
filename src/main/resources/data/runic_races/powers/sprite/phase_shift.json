{
  "type": "origins:multiple",
  "name": "power.runic_races.sprite.phase_shift.name",
  "description": "power.runic_races.sprite.phase_shift.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "phase_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 900,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:sprite/phase_shift_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:sprite/phase_shift_cooldown_timer",
        "change": -1
      }
    }
  },

  "phase_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "runic_races:sprite/phase_shift_cooldown_timer",
          "comparison": "==",
          "compare_to": 0
        },
        {
          "type": "origins:damage_condition",
          "damage_condition": {
            "type": "origins:amount",
            "comparison": ">=",
            "compare_to": 8.0
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 20,
            "amplifier": 4,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:sprite/phase_shift_cooldown_timer",
          "change": 900
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You phase out of existence!\",\"color\":\"aqua\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:end_rod",
          "count": 25,
          "speed": 0.5,
          "spread": {
            "x": 1.0,
            "y": 1.5,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit for 4+ hearts, become invulnerable for 1 second (Resistance V). 45-second cooldown."
  }
}
