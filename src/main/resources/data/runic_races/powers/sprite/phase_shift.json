{
  "type": "origins:multiple",
  "name": "power.runic_races.sprite.phase_shift.name",
  "description": "power.runic_races.sprite.phase_shift.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "phase_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1800,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:sprite/phase_shift_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:sprite/phase_shift_cooldown_timer",
        "change": -1
      }
    }
  },
  "phase_trigger": {
    "type": "origins:self_action_when_hit",
    "damage_condition": {
      "type": "origins:amount",
      "comparison": ">=",
      "compare_to": 8.0
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:sprite/phase_shift_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 20,
            "amplifier": 4,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:sprite/phase_shift_cooldown_timer",
          "change": 1800
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You phase out of existence!\",\"color\":\"aqua\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.amethyst_block.chime",
          "volume": 0.9,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.allay.ambient_without_item",
          "volume": 0.5,
          "pitch": 2.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:end_rod",
          "count": 25,
          "speed": 0.8,
          "spread": {
            "x": 0.3,
            "y": 0.5,
            "z": 0.3
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.3 0.9 0.9 0.4 ~ ~1 ~ 0.5 0.5 0.5 0.5 20 force"
        }
      ]
    }
  }
}
