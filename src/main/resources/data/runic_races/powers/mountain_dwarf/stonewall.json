{
  "type": "origins:multiple",
  "name": "power.runic_races.mountain_dwarf.stonewall.name",
  "description": "power.runic_races.mountain_dwarf.stonewall.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "on_hit_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:mountain_dwarf/stonewall_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:mountain_dwarf/stonewall_cooldown_timer",
        "change": -1
      }
    }
  },

  "on_hit_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:mountain_dwarf/stonewall_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 30,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:mountain_dwarf/stonewall_cooldown_timer",
          "change": 200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Stone shields you!\",\"color\":\"gray\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:block",
            "block_state": "minecraft:stone"
          },
          "count": 15,
          "speed": 0.3,
          "spread": {
            "x": 1.0,
            "y": 1.0,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit, gain Resistance I for 1.5 seconds, reducing damage by ~15%%. 10-second cooldown."
  }
}