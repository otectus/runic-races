{
  "type": "origins:multiple",
  "name": "power.runic_races.deep_dwarf.tremorsense.name",
  "description": "power.runic_races.deep_dwarf.tremorsense.description",
  "subpowers": [
    "night_vision",
    "detect_nearby",
    "badge"
  ],

  "night_vision": {
    "type": "origins:night_vision",
    "strength": 1.0
  },

  "detect_nearby": {
    "type": "origins:action_over_time",
    "interval": 100,
    "entity_action": {
      "type": "origins:area_of_effect",
      "radius": 12,
      "bientity_action": {
        "type": "origins:target_action",
        "action": {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:glowing",
            "duration": 100,
            "amplifier": 0,
            "is_ambient": true,
            "show_particles": false,
            "show_icon": false
          }
        }
      },
      "bientity_condition": {
        "type": "origins:target_condition",
        "condition": {
          "type": "origins:living"
        }
      }
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/star.png",
    "text": "Grants permanent night vision. Every 5 seconds, nearby living entities within 12 blocks gain Glowing, representing tremorsense detection."
  }
}