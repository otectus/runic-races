{
  "type": "origins:multiple",
  "name": "power.runic_races.deep_dwarf.tremorsense.name",
  "description": "power.runic_races.deep_dwarf.tremorsense.description",
  "subpowers": [
    "night_vision",
    "cooldown_timer",
    "cooldown_decay",
    "active_ping"
  ],

  "night_vision": {
    "type": "origins:night_vision",
    "strength": 1.0
  },

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:deep_dwarf/tremorsense_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:deep_dwarf/tremorsense_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ping": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.secondary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:deep_dwarf/tremorsense_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "runic_races:tremor_ping",
          "radius": 18.0,
          "duration_ticks": 40
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:deep_dwarf/tremorsense_cooldown_timer",
          "change": 300
        }
      ]
    }
  }
}
