{
  "type": "origins:multiple",
  "name": "power.runic_races.deep_dwarf.stoneshape.name",
  "description": "power.runic_races.deep_dwarf.stoneshape.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:deep_dwarf/stoneshape_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:deep_dwarf/stoneshape_cooldown_timer",
        "change": -1
      }
    }
  },

  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:deep_dwarf/stoneshape_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:haste",
            "duration": 200,
            "amplifier": 2,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:deep_dwarf/stoneshape_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You reshape the stone around you!\",\"color\":\"dark_gray\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.deepslate.break",
          "volume": 0.9,
          "pitch": 0.6
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.player.levelup",
          "volume": 0.3,
          "pitch": 0.8
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:block",
            "params": "minecraft:deepslate"
          },
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 0.5, "y": 0.8, "z": 0.5 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.8, "y": 0.6, "z": 0.2 },
            "scale": 0.6
          },
          "count": 12,
          "speed": 0.2,
          "spread": { "x": 0.4, "y": 0.5, "z": 0.4 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.85 0.65 0.25 0.7 ~ ~0.5 ~ 0.3 0.3 0.3 0.2 20 force"
        }
      ]
    }
  }
}