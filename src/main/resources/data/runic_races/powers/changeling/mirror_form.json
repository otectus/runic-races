{
  "type": "origins:multiple",
  "name": "power.runic_races.changeling.mirror_form.name",
  "description": "power.runic_races.changeling.mirror_form.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "mirror_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:changeling/mirror_form_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:changeling/mirror_form_cooldown_timer",
        "change": -1
      }
    }
  },

  "mirror_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:changeling/mirror_form_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:strength",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:changeling/mirror_form_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You mirror your attacker's strength!\",\"color\":\"dark_purple\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:reverse_portal",
          "count": 25,
          "speed": 0.5,
          "spread": {
            "x": 1.0,
            "y": 1.5,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit by an entity, gain Strength I and Speed I for 10 seconds. 60-second cooldown."
  }
}
