{
  "type": "origins:multiple",
  "name": "power.runic_races.changeling.mirror_form.name",
  "description": "power.runic_races.changeling.mirror_form.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "mirror_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:changeling/mirror_form_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:changeling/mirror_form_cooldown_timer",
        "change": -1
      }
    }
  },

  "mirror_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:changeling/mirror_form_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:strength",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:changeling/mirror_form_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You mirror your attacker's strength!\",\"color\":\"dark_purple\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.glass.break",
          "volume": 0.5,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.evoker.prepare_attack",
          "volume": 0.3,
          "pitch": 2.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 1.0, "y": 1.0, "z": 1.0 },
            "scale": 1.0
          },
          "count": 12,
          "speed": 0.3,
          "spread": { "x": 0.4, "y": 0.8, "z": 0.4 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:reverse_portal",
          "count": 10,
          "speed": 0.5,
          "spread": { "x": 0.5, "y": 0.5, "z": 0.5 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:enchanted_hit ~ ~1 ~ 0.6 0.8 0.6 0.2 20 force"
        }
      ]
    }
  }
}
