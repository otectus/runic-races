{
  "type": "origins:multiple",
  "name": "power.runic_races.changeling.assume_form.name",
  "description": "power.runic_races.changeling.assume_form.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:changeling/assume_form_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:changeling/assume_form_cooldown_timer",
        "change": -1
      }
    }
  },

  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:changeling/assume_form_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 120,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 120,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:changeling/assume_form_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You shift into another form...\",\"color\":\"gray\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.illusioner.mirror_move",
          "volume": 0.8,
          "pitch": 1.0
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.illusioner.prepare_blindness",
          "volume": 0.4,
          "pitch": 1.5
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:large_smoke",
          "count": 30,
          "speed": 0.3,
          "spread": { "x": 0.5, "y": 1.0, "z": 0.5 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:reverse_portal",
          "count": 15,
          "speed": 0.5,
          "spread": { "x": 0.3, "y": 0.8, "z": 0.3 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:large_smoke ~ ~1 ~ 0.5 1.0 0.5 0.03 40 force"
        }
      ]
    }
  }
}
