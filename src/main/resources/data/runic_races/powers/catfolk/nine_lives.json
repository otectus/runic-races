{
  "type": "origins:multiple",
  "name": "power.runic_races.catfolk.nine_lives.name",
  "description": "power.runic_races.catfolk.nine_lives.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "life_save_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 12000,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:catfolk/nine_lives_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:catfolk/nine_lives_cooldown_timer",
        "change": -1
      }
    }
  },

  "life_save_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:catfolk/nine_lives_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:health",
            "comparison": "<=",
            "compare_to": 2.0
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:execute_command",
            "command": "effect give @s minecraft:instant_health 1 0"
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:resistance",
              "duration": 40,
              "amplifier": 4,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:regeneration",
              "duration": 60,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:catfolk/nine_lives_cooldown_timer",
            "change": 12000
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"A life is spent... but you persist!\",\"color\":\"yellow\",\"bold\":true}"
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:totem_of_undying",
            "count": 30,
            "speed": 0.5,
            "spread": {
              "x": 1.0,
              "y": 2.0,
              "z": 1.0
            }
          }
        ]
      }
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When reduced to 1 heart or less, heal and gain Resistance V for 2 seconds plus Regeneration II for 3 seconds. 10-minute cooldown."
  }
}