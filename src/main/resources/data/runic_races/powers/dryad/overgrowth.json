{
  "type": "origins:multiple",
  "name": "power.runic_races.dryad.overgrowth.name",
  "description": "power.runic_races.dryad.overgrowth.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 3600,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dryad/overgrowth_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dryad/overgrowth_cooldown_timer",
        "change": -1
      }
    }
  },
  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:dryad/overgrowth_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:regeneration",
            "duration": 100,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:area_of_effect",
          "radius": 5,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:regeneration",
                "duration": 100,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": true,
                "show_icon": true
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:entity_type",
              "entity_type": "minecraft:player"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:dryad/overgrowth_cooldown_timer",
          "change": 3600
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Life bursts forth around you!\",\"color\":\"green\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.azalea.place",
          "volume": 0.9,
          "pitch": 0.6
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.experience_orb.pickup",
          "volume": 0.4,
          "pitch": 0.8
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:happy_villager",
          "count": 25,
          "speed": 0.5,
          "spread": {
            "x": 4.0,
            "y": 1.0,
            "z": 4.0
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.2 0.9 0.2 1.0 ~ ~1 ~ 3.0 1.5 3.0 0.3 20 force"
        }
      ]
    }
  }
}
