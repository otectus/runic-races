{
  "type": "origins:multiple",
  "name": "power.runic_races.dryad.bark_skin.name",
  "description": "power.runic_races.dryad.bark_skin.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "bark_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1800,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dryad/bark_skin_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dryad/bark_skin_cooldown_timer",
        "change": -1
      }
    }
  },
  "bark_trigger": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:dryad/bark_skin_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.4
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:resistance",
              "duration": 120,
              "amplifier": 0,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:dryad/bark_skin_cooldown_timer",
            "change": 1800
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Bark hardens around your skin!\",\"color\":\"dark_green\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:block.wood.break",
            "volume": 0.8,
            "pitch": 0.5
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:block.nether_wood.break",
            "volume": 0.4,
            "pitch": 0.6
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:composter",
            "count": 15,
            "speed": 0.3,
            "spread": {
              "x": 0.5,
              "y": 0.8,
              "z": 0.5
            }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:dust 0.55 0.35 0.15 1.2 ~ ~1 ~ 0.6 1.0 0.6 0.2 20 force"
          }
        ]
      }
    }
  }
}
