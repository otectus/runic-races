{
  "type": "origins:multiple",
  "name": "power.runic_races.high_elf.arcane_reflex.name",
  "description": "power.runic_races.high_elf.arcane_reflex.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "reflex_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
        "change": -1
      }
    }
  },

  "reflex_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
          "comparison": "==",
          "compare_to": 0
        },
        {
          "type": "origins:damage_condition",
          "damage_condition": {
            "type": "origins:or",
            "conditions": [
              {
                "type": "origins:name",
                "name": "magic"
              },
              {
                "type": "origins:name",
                "name": "indirectMagic"
              }
            ]
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:regeneration",
            "duration": 60,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
          "change": 300
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Arcane energy flows through you!\",\"color\":\"light_purple\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:enchant",
          "count": 25,
          "speed": 0.5,
          "spread": {
            "x": 1.0,
            "y": 1.5,
            "z": 1.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When struck by magical damage, gain Regeneration II and Speed I for 3 seconds. 15-second cooldown."
  }
}
