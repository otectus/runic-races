{
  "type": "origins:multiple",
  "name": "power.runic_races.high_elf.arcane_reflex.name",
  "description": "power.runic_races.high_elf.arcane_reflex.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "reflex_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
        "change": -1
      }
    }
  },

  "reflex_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:and",
      "conditions": [
        {
          "type": "origins:resource",
          "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
          "comparison": "==",
          "compare_to": 0
        },
        {
          "type": "origins:damage_condition",
          "damage_condition": {
            "type": "origins:or",
            "conditions": [
              {
                "type": "origins:name",
                "name": "magic"
              },
              {
                "type": "origins:name",
                "name": "indirectMagic"
              }
            ]
          }
        }
      ]
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:regeneration",
            "duration": 60,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:high_elf/arcane_reflex_cooldown_timer",
          "change": 300
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Arcane energy flows through you!\",\"color\":\"light_purple\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.evoker.cast_spell",
          "volume": 0.6,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.amethyst_cluster.break",
          "volume": 0.4,
          "pitch": 1.2
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:enchant",
          "count": 20,
          "speed": 0.5,
          "spread": { "x": 0.5, "y": 1.0, "z": 0.5 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:witch",
          "count": 10,
          "speed": 0.3,
          "spread": { "x": 0.5, "y": 0.8, "z": 0.5 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.6, "y": 0.2, "z": 0.9 },
            "scale": 0.8
          },
          "count": 15,
          "speed": 0.2,
          "spread": { "x": 0.6, "y": 1.0, "z": 0.6 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:enchant ~ ~2 ~ 0.5 0.5 0.5 1.0 30 force"
        }
      ]
    }
  }
}
