{
  "type": "origins:multiple",
  "name": "power.runic_races.wood_elf.forest_stride.name",
  "description": "power.runic_races.wood_elf.forest_stride.description",
  "subpowers": [
    "speed_bonus",
    "passive_regen",
    "badge"
  ],

  "speed_bonus": {
    "type": "origins:attribute",
    "modifier": {
      "attribute": "minecraft:generic.movement_speed",
      "operation": "multiply_total",
      "value": 0.15,
      "name": "Forest Stride Speed Bonus"
    }
  },

  "passive_regen": {
    "type": "origins:action_over_time",
    "interval": 100,
    "entity_action": {
      "type": "origins:execute_command",
      "command": "effect give @s minecraft:instant_health 1 0 true"
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/star.png",
    "text": "Grants +15%% movement speed and slow passive health regeneration (0.5 HP every 5 seconds). Represents natural forest agility and nature's embrace."
  }
}
