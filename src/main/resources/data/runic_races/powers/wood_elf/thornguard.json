{
  "type": "origins:multiple",
  "name": "power.runic_races.wood_elf.thornguard.name",
  "description": "power.runic_races.wood_elf.thornguard.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "thorn_retaliation"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 100,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
        "change": -1
      }
    }
  },
  "thorn_retaliation": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "bientity_action": {
      "type": "origins:invert",
      "action": {
        "type": "origins:damage",
        "amount": 1.0,
        "source": {
          "name": "thorns",
          "bypasses_armor": false
        }
      }
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
          "change": 100
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Thorns lash out at your attacker!\",\"color\":\"green\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.sweet_berry_bush.hurt",
          "volume": 0.7,
          "pitch": 0.8
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.player.attack.crit",
          "volume": 0.3,
          "pitch": 0.8
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:crit",
          "count": 15,
          "speed": 0.5,
          "spread": {
            "x": 0.5,
            "y": 0.8,
            "z": 0.5
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.1 0.5 0.1 0.7 ~ ~1 ~ 0.6 1.0 0.6 0.3 12 force"
        }
      ]
    }
  }
}
