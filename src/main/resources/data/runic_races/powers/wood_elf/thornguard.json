{
  "type": "origins:multiple",
  "name": "power.runic_races.wood_elf.thornguard.name",
  "description": "power.runic_races.wood_elf.thornguard.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "thorn_retaliation",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 100,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
        "change": -1
      }
    }
  },

  "thorn_retaliation": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "bientity_action": {
      "type": "origins:invert",
      "action": {
        "type": "origins:damage",
        "amount": 1.0,
        "source": {
          "name": "thorns",
          "bypasses_armor": false
        }
      }
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wood_elf/thornguard_cooldown_timer",
          "change": 100
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Thorns lash out at your attacker!\",\"color\":\"green\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:crit",
          "count": 15,
          "speed": 0.3,
          "spread": {
            "x": 0.8,
            "y": 1.0,
            "z": 0.8
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit, thorns retaliate for 1 damage to the attacker. 5-second cooldown."
  }
}
