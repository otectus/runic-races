{
  "type": "origins:multiple",
  "name": "power.runic_races.wood_elf.canopy_meld.name",
  "description": "power.runic_races.wood_elf.canopy_meld.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "activation"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wood_elf/canopy_meld_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wood_elf/canopy_meld_cooldown_timer",
        "change": -1
      }
    }
  },

  "activation": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wood_elf/canopy_meld_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 200,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": false,
            "show_icon": true
          }
        },
        {
          "type": "origins:area_of_effect",
          "radius": 16,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:glowing",
                "duration": 200,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": false,
                "show_icon": false
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:living"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wood_elf/canopy_meld_cooldown_timer",
          "change": 1200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You meld into the canopy...\",\"color\":\"dark_green\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.azalea_leaves.place",
          "volume": 0.8,
          "pitch": 0.8
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.moss.place",
          "volume": 0.5,
          "pitch": 0.6
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:composter",
          "count": 25,
          "speed": 0.3,
          "spread": { "x": 1.0, "y": 1.0, "z": 1.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.15, "y": 0.5, "z": 0.1 },
            "scale": 0.5
          },
          "count": 15,
          "speed": 0.2,
          "spread": { "x": 1.5, "y": 1.5, "z": 1.5 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:composter ~ ~3 ~ 2.0 0.5 2.0 0.01 30 force"
        }
      ]
    }
  }
}
