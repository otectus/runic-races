{
  "type": "origins:multiple",
  "name": "power.runic_races.wolfkin.pack_howl.name",
  "description": "power.runic_races.wolfkin.pack_howl.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "howl_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
        "change": -1
      }
    }
  },

  "howl_trigger": {
    "type": "origins:self_action_on_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 16,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:speed",
                "duration": 60,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": true,
                "show_icon": true
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:entity_type",
              "entity_type": "minecraft:player"
            }
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
          "change": 300
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your howl rallies the pack!\",\"color\":\"gold\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:note",
          "count": 10,
          "speed": 0.5,
          "spread": {
            "x": 2.0,
            "y": 2.0,
            "z": 2.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "On hitting a mob, allies within 16 blocks gain Speed I for 3 seconds. 15-second cooldown."
  }
}