{
  "type": "origins:multiple",
  "name": "power.runic_races.wolfkin.pack_howl.name",
  "description": "power.runic_races.wolfkin.pack_howl.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "howl_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 300,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
        "change": -1
      }
    }
  },

  "howl_trigger": {
    "type": "origins:self_action_on_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 16,
          "bientity_action": {
            "type": "origins:target_action",
            "action": {
              "type": "origins:apply_effect",
              "effect": {
                "effect": "minecraft:speed",
                "duration": 60,
                "amplifier": 0,
                "is_ambient": false,
                "show_particles": true,
                "show_icon": true
              }
            }
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:entity_type",
              "entity_type": "minecraft:player"
            }
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 60,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wolfkin/pack_howl_cooldown_timer",
          "change": 300
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your howl rallies the pack!\",\"color\":\"gold\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.wolf.howl",
          "volume": 1.0,
          "pitch": 0.8
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.warden.sonic_charge",
          "volume": 0.2,
          "pitch": 2.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:sonic_boom",
          "count": 3,
          "speed": 0.2,
          "spread": { "x": 2.0, "y": 1.0, "z": 2.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.9, "y": 0.7, "z": 0.2 },
            "scale": 0.7
          },
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 4.0, "y": 2.0, "z": 4.0 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.9 0.75 0.25 0.8 ~ ~1 ~ 4.0 1.0 4.0 0.02 50 force"
        }
      ]
    }
  }
}
