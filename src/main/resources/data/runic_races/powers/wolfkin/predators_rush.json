{
  "type": "origins:multiple",
  "name": "power.runic_races.wolfkin.predators_rush.name",
  "description": "power.runic_races.wolfkin.predators_rush.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 600,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wolfkin/predators_rush_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wolfkin/predators_rush_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wolfkin/predators_rush_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:add_velocity",
          "z": 2.0,
          "space": "local"
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 40,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wolfkin/predators_rush_cooldown_timer",
          "change": 600
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You surge forward!\",\"color\":\"gold\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:crit",
          "count": 20,
          "speed": 0.5,
          "spread": {
            "x": 0.5,
            "y": 1.0,
            "z": 0.5
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to dash forward with a burst of speed. Grants Speed II for 2 seconds. 30-second cooldown."
  }
}