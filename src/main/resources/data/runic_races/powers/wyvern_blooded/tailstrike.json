{
  "type": "origins:multiple",
  "name": "power.runic_races.wyvern_blooded.tailstrike.name",
  "description": "power.runic_races.wyvern_blooded.tailstrike.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "tail_counter",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
        "change": -1
      }
    }
  },

  "tail_counter": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "bientity_action": {
      "type": "origins:invert",
      "action": {
        "type": "origins:damage",
        "amount": 4.0,
        "source": {
          "name": "mob",
          "bypasses_armor": false
        }
      }
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
          "change": 200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your tail lashes out!\",\"color\":\"dark_purple\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:sweep_attack",
          "count": 8,
          "speed": 0.3,
          "spread": {
            "x": 1.5,
            "y": 1.0,
            "z": 1.5
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When hit, your tail lashes out dealing 2 hearts of damage back to the attacker. 10-second cooldown."
  }
}