{
  "type": "origins:multiple",
  "name": "power.runic_races.wyvern_blooded.tailstrike.name",
  "description": "power.runic_races.wyvern_blooded.tailstrike.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "tail_counter"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
        "change": -1
      }
    }
  },
  "tail_counter": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "bientity_action": {
      "type": "origins:invert",
      "action": {
        "type": "origins:damage",
        "amount": 4.0,
        "source": {
          "name": "mob",
          "bypasses_armor": false
        }
      }
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:change_resource",
          "resource": "runic_races:wyvern_blooded/tailstrike_cooldown_timer",
          "change": 200
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"Your tail lashes out!\",\"color\":\"dark_purple\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.player.attack.sweep",
          "volume": 0.8,
          "pitch": 0.8
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.phantom.bite",
          "volume": 0.4,
          "pitch": 0.8
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:sweep_attack",
          "count": 8,
          "speed": 0.3,
          "spread": {
            "x": 0.5,
            "y": 0.3,
            "z": 0.5
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.5 0.2 0.6 0.7 ~ ~1 ~ 0.8 0.5 0.8 0.3 12 force"
        }
      ]
    }
  }
}
