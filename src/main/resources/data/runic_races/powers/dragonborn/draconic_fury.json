{
  "type": "origins:multiple",
  "name": "power.runic_races.dragonborn.draconic_fury.name",
  "description": "power.runic_races.dragonborn.draconic_fury.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "fury_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
        "change": -1
      }
    }
  },

  "fury_trigger": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.3
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:area_of_effect",
            "radius": 3,
            "bientity_action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:damage",
                  "amount": 4.0,
                  "source": {
                    "name": "onFire",
                    "bypasses_armor": false,
                    "fire": true
                  }
                },
                {
                  "type": "origins:target_action",
                  "action": {
                    "type": "origins:set_on_fire",
                    "duration": 3
                  }
                }
              ]
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
            "change": 1200
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Draconic fury erupts!\",\"color\":\"red\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.blaze.shoot",
            "volume": 0.9,
            "pitch": 0.6
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.generic.explode",
            "volume": 0.4,
            "pitch": 1.5
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:flame",
            "count": 30,
            "speed": 0.5,
            "spread": { "x": 1.5, "y": 1.0, "z": 1.5 }
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:lava",
            "count": 10,
            "speed": 0.1,
            "spread": { "x": 1.0, "y": 0.5, "z": 1.0 }
          },
          {
            "type": "origins:spawn_particles",
            "particle": {
              "type": "minecraft:dust",
              "color": { "x": 0.8, "y": 0.1, "z": 0.0 },
              "scale": 1.0
            },
            "count": 15,
            "speed": 0.3,
            "spread": { "x": 1.5, "y": 1.0, "z": 1.5 }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:lava ~ ~1 ~ 1.5 0.5 1.5 0.01 20 force"
          }
        ]
      }
    }
  }
}
