{
  "type": "origins:multiple",
  "name": "power.runic_races.dragonborn.draconic_fury.name",
  "description": "power.runic_races.dragonborn.draconic_fury.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "fury_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
        "change": -1
      }
    }
  },

  "fury_trigger": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:health",
            "comparison": "<=",
            "compare_to": 0.3,
            "comparison_type": "percentage"
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:area_of_effect",
            "radius": 3,
            "bientity_action": {
              "type": "origins:and",
              "actions": [
                {
                  "type": "origins:damage",
                  "amount": 4.0,
                  "source": {
                    "name": "onFire",
                    "bypasses_armor": false,
                    "fire": true
                  }
                },
                {
                  "type": "origins:target_action",
                  "action": {
                    "type": "origins:set_on_fire",
                    "duration": 3
                  }
                }
              ]
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:dragonborn/draconic_fury_cooldown_timer",
            "change": 1200
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Draconic fury erupts!\",\"color\":\"red\",\"bold\":true}"
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:flame",
            "count": 40,
            "speed": 0.5,
            "spread": {
              "x": 2.0,
              "y": 1.5,
              "z": 2.0
            }
          }
        ]
      }
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When below 30%% HP, unleash a fire burst dealing 2 hearts in a 3-block radius and igniting targets for 3 seconds. 60-second cooldown."
  }
}