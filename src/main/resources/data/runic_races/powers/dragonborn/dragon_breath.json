{
  "type": "origins:multiple",
  "name": "power.runic_races.dragonborn.dragon_breath.name",
  "description": "power.runic_races.dragonborn.dragon_breath.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 5,
          "bientity_action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:damage",
                "amount": 6.0,
                "source": {
                  "name": "onFire",
                  "bypasses_armor": false,
                  "fire": true
                }
              },
              {
                "type": "origins:target_action",
                "action": {
                  "type": "origins:set_on_fire",
                  "duration": 8
                }
              }
            ]
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You unleash your dragon breath!\",\"color\":\"red\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:flame",
          "count": 50,
          "speed": 0.8,
          "spread": {
            "x": 3.0,
            "y": 1.5,
            "z": 3.0
          }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:lava",
          "count": 15,
          "speed": 0.3,
          "spread": {
            "x": 2.0,
            "y": 1.0,
            "z": 2.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to unleash dragon breath. Deals 3 hearts of fire damage and ignites enemies in a 5-block radius for 8 seconds. 120-second cooldown."
  }
}