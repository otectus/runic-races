{
  "type": "origins:multiple",
  "name": "power.runic_races.dragonborn.dragon_breath.name",
  "description": "power.runic_races.dragonborn.dragon_breath.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 2400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:area_of_effect",
          "radius": 5,
          "bientity_action": {
            "type": "origins:and",
            "actions": [
              {
                "type": "origins:damage",
                "amount": 6.0,
                "source": {
                  "name": "onFire",
                  "bypasses_armor": false,
                  "fire": true
                }
              },
              {
                "type": "origins:target_action",
                "action": {
                  "type": "origins:set_on_fire",
                  "duration": 8
                }
              }
            ]
          },
          "bientity_condition": {
            "type": "origins:target_condition",
            "condition": {
              "type": "origins:living"
            }
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:dragonborn/dragon_breath_cooldown_timer",
          "change": 2400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You unleash your dragon breath!\",\"color\":\"red\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.ender_dragon.growl",
          "volume": 0.9,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.blaze.shoot",
          "volume": 0.6,
          "pitch": 0.6
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:flame",
          "count": 60,
          "speed": 0.3,
          "spread": { "x": 3.0, "y": 1.0, "z": 3.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:lava",
          "count": 15,
          "speed": 0.1,
          "spread": { "x": 2.0, "y": 0.5, "z": 2.0 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 1.0, "y": 0.5, "z": 0.0 },
            "scale": 1.2
          },
          "count": 20,
          "speed": 0.3,
          "spread": { "x": 2.5, "y": 1.0, "z": 2.5 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:flame ~ ~1 ~2 1.5 0.5 1.5 0.1 80 force"
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:smoke ~ ~1 ~2 2.0 1.0 2.0 0.05 30 force"
        }
      ]
    }
  }
}
