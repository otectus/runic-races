{
  "type": "origins:multiple",
  "name": "power.runic_races.nomad.pathfinders_mark.name",
  "description": "power.runic_races.nomad.pathfinders_mark.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 3600,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:nomad/pathfinders_mark_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:nomad/pathfinders_mark_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:nomad/pathfinders_mark_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:add_velocity",
          "z": 2.0,
          "space": "local"
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 60,
            "amplifier": 1,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:nomad/pathfinders_mark_cooldown_timer",
          "change": 3600
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You surge forward along the pathfinder's trail!\",\"color\":\"aqua\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.enderman.teleport",
          "volume": 0.7,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.ender_eye.launch",
          "volume": 0.4,
          "pitch": 1.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:reverse_portal",
          "count": 20,
          "speed": 0.5,
          "spread": { "x": 0.3, "y": 0.8, "z": 0.3 }
        },
        {
          "type": "origins:spawn_particles",
          "particle": {
            "type": "minecraft:dust",
            "color": { "x": 0.3, "y": 0.9, "z": 0.9 },
            "scale": 0.5
          },
          "count": 15,
          "speed": 0.3,
          "spread": { "x": 0.5, "y": 0.5, "z": 0.5 }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:reverse_portal ~ ~1 ~ 0.1 0.5 0.1 0.5 30 force"
        }
      ]
    }
  }
}
