{
  "type": "origins:multiple",
  "name": "power.runic_races.nomad.sand_shield.name",
  "description": "power.runic_races.nomad.sand_shield.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "on_hit_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:nomad/sand_shield_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:nomad/sand_shield_cooldown_timer",
        "change": -1
      }
    }
  },
  "on_hit_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:nomad/sand_shield_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:resistance",
            "duration": 40,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:nomad/sand_shield_cooldown_timer",
          "change": 400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"The desert shields you!\",\"color\":\"yellow\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.sand.break",
          "volume": 0.7,
          "pitch": 0.8
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.iron_golem.hurt",
          "volume": 0.3,
          "pitch": 1.8
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.9 0.8 0.5 1.0 ~ ~1 ~ 0.8 1.0 0.8 0.3 15 force"
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.7 0.6 0.3 0.8 ~ ~1 ~ 1.0 1.5 1.0 0.2 20 force"
        }
      ]
    }
  }
}
