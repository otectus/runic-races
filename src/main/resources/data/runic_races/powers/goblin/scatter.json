{
  "type": "origins:multiple",
  "name": "power.runic_races.goblin.scatter.name",
  "description": "power.runic_races.goblin.scatter.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "on_hit_trigger"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 400,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:goblin/scatter_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:goblin/scatter_cooldown_timer",
        "change": -1
      }
    }
  },
  "on_hit_trigger": {
    "type": "origins:self_action_when_hit",
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:goblin/scatter_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:speed",
            "duration": 20,
            "amplifier": 2,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:apply_effect",
          "effect": {
            "effect": "minecraft:invisibility",
            "duration": 20,
            "amplifier": 0,
            "is_ambient": false,
            "show_particles": true,
            "show_icon": true
          }
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:goblin/scatter_cooldown_timer",
          "change": 400
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"You scatter into the shadows!\",\"color\":\"dark_green\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.firework_rocket.blast",
          "volume": 0.5,
          "pitch": 2.0
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.firework_rocket.twinkle",
          "volume": 0.3,
          "pitch": 2.0
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:smoke",
          "count": 25,
          "speed": 0.5,
          "spread": {
            "x": 0.5,
            "y": 0.5,
            "z": 0.5
          }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:firework",
          "count": 5,
          "speed": 0.3,
          "spread": {
            "x": 0.3,
            "y": 0.3,
            "z": 0.3
          }
        }
      ]
    }
  }
}
