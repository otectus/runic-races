{
  "type": "origins:multiple",
  "name": "power.runic_races.revenant.grave_call.name",
  "description": "power.runic_races.revenant.grave_call.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 6000,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:revenant/grave_call_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:revenant/grave_call_cooldown_timer",
        "change": -1
      }
    }
  },

  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:revenant/grave_call_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "summon minecraft:zombie ~ ~ ~ {CustomName:'\"Grave Servant\"',PersistenceRequired:1b,Attributes:[{Name:generic.max_health,Base:30},{Name:generic.attack_damage,Base:6}],HandItems:[{id:'minecraft:iron_sword',Count:1b},{}],ArmorItems:[{},{},{},{id:'minecraft:iron_helmet',Count:1b}]}"
        },
        {
          "type": "origins:execute_command",
          "command": "summon minecraft:zombie ~ ~ ~ {CustomName:'\"Grave Servant\"',PersistenceRequired:1b,Attributes:[{Name:generic.max_health,Base:30},{Name:generic.attack_damage,Base:6}],HandItems:[{id:'minecraft:iron_sword',Count:1b},{}],ArmorItems:[{},{},{},{id:'minecraft:iron_helmet',Count:1b}]}"
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:revenant/grave_call_cooldown_timer",
          "change": 6000
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"The grave answers your call!\",\"color\":\"dark_gray\",\"bold\":true}"
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:soul",
          "count": 30,
          "speed": 0.5,
          "spread": {
            "x": 2.0,
            "y": 1.5,
            "z": 2.0
          }
        }
      ]
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "Press primary active key to summon two Grave Servants (armored zombies with iron swords). 300-second cooldown."
  }
}