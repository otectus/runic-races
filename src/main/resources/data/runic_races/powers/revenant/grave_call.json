{
  "type": "origins:multiple",
  "name": "power.runic_races.revenant.grave_call.name",
  "description": "power.runic_races.revenant.grave_call.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "active_ability"
  ],
  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 6000,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 2
    },
    "min_action": null,
    "max_action": null
  },
  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:revenant/grave_call_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:revenant/grave_call_cooldown_timer",
        "change": -1
      }
    }
  },
  "active_ability": {
    "type": "origins:active_self",
    "key": {
      "key": "key.origins.primary_active",
      "continuous": false
    },
    "condition": {
      "type": "origins:resource",
      "resource": "runic_races:revenant/grave_call_cooldown_timer",
      "comparison": "==",
      "compare_to": 0
    },
    "entity_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "runic_races:summon_minion",
          "entity": "runic_races:grave_servant",
          "count": 2,
          "duration_ticks": 1200,
          "radius": 2.5
        },
        {
          "type": "origins:change_resource",
          "resource": "runic_races:revenant/grave_call_cooldown_timer",
          "change": 6000
        },
        {
          "type": "origins:execute_command",
          "command": "title @s actionbar {\"text\":\"The grave answers your call!\",\"color\":\"dark_gray\",\"bold\":true}"
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:entity.wither.spawn",
          "volume": 0.6,
          "pitch": 1.5
        },
        {
          "type": "origins:play_sound",
          "sound": "minecraft:block.soul_sand.break",
          "volume": 0.8,
          "pitch": 0.5
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:soul",
          "count": 35,
          "speed": 0.2,
          "spread": {
            "x": 2.0,
            "y": 0.5,
            "z": 2.0
          }
        },
        {
          "type": "origins:spawn_particles",
          "particle": "minecraft:soul_fire_flame",
          "count": 20,
          "speed": 0.2,
          "spread": {
            "x": 1.5,
            "y": 0.5,
            "z": 1.5
          }
        },
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:dust 0.4 0.4 0.4 1.0 ~ ~1 ~ 2.0 0.5 2.0 0.2 25 force"
        }
      ]
    }
