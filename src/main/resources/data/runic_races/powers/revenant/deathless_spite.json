{
  "type": "origins:multiple",
  "name": "power.runic_races.revenant.deathless_spite.name",
  "description": "power.runic_races.revenant.deathless_spite.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "spite_trigger"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": false,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
        "change": -1
      }
    }
  },

  "spite_trigger": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:relative_health",
            "comparison": "<=",
            "compare_to": 0.25
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:strength",
              "duration": 100,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:resistance",
              "duration": 100,
              "amplifier": 0,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
            "change": 1200
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Death will not claim you so easily!\",\"color\":\"gray\",\"bold\":true}"
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.wither_skeleton.ambient",
            "volume": 0.8,
            "pitch": 0.8
          },
          {
            "type": "origins:play_sound",
            "sound": "minecraft:entity.wither.hurt",
            "volume": 0.3,
            "pitch": 1.5
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:soul_fire_flame",
            "count": 20,
            "speed": 0.3,
            "spread": { "x": 0.5, "y": 1.0, "z": 0.5 }
          },
          {
            "type": "origins:spawn_particles",
            "particle": {
              "type": "minecraft:dust",
              "color": { "x": 0.3, "y": 0.4, "z": 0.6 },
              "scale": 0.8
            },
            "count": 15,
            "speed": 0.3,
            "spread": { "x": 0.8, "y": 1.5, "z": 0.8 }
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:enchanted_hit",
            "count": 8,
            "speed": 0.2,
            "spread": { "x": 0.5, "y": 0.8, "z": 0.5 }
          },
          {
            "type": "origins:execute_command",
            "command": "particle minecraft:soul_fire_flame ~ ~1 ~ 0.5 1.0 0.5 0.05 25 force"
          }
        ]
      }
    }
  }
}
