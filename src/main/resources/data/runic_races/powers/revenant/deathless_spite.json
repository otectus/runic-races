{
  "type": "origins:multiple",
  "name": "power.runic_races.revenant.deathless_spite.name",
  "description": "power.runic_races.revenant.deathless_spite.description",
  "subpowers": [
    "cooldown_timer",
    "cooldown_decay",
    "spite_trigger",
    "badge"
  ],

  "cooldown_timer": {
    "type": "origins:resource",
    "min": 0,
    "max": 1200,
    "start_value": 0,
    "hud_render": {
      "should_render": true,
      "sprite_location": "origins:textures/gui/community/spade.png",
      "bar_index": 1
    },
    "min_action": null,
    "max_action": null
  },

  "cooldown_decay": {
    "type": "origins:action_over_time",
    "interval": 1,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:resource",
        "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
        "comparison": ">",
        "compare_to": 0
      },
      "if_action": {
        "type": "origins:change_resource",
        "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
        "change": -1
      }
    }
  },

  "spite_trigger": {
    "type": "origins:action_over_time",
    "interval": 20,
    "entity_action": {
      "type": "origins:if_else",
      "condition": {
        "type": "origins:and",
        "conditions": [
          {
            "type": "origins:resource",
            "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
            "comparison": "==",
            "compare_to": 0
          },
          {
            "type": "origins:health",
            "comparison": "<=",
            "compare_to": 0.1
          }
        ]
      },
      "if_action": {
        "type": "origins:and",
        "actions": [
          {
            "type": "origins:apply_effect",
            "effect": {
              "effect": "minecraft:strength",
              "duration": 100,
              "amplifier": 1,
              "is_ambient": false,
              "show_particles": true,
              "show_icon": true
            }
          },
          {
            "type": "origins:change_resource",
            "resource": "runic_races:revenant/deathless_spite_cooldown_timer",
            "change": 1200
          },
          {
            "type": "origins:execute_command",
            "command": "title @s actionbar {\"text\":\"Death will not claim you so easily!\",\"color\":\"gray\",\"bold\":true}"
          },
          {
            "type": "origins:spawn_particles",
            "particle": "minecraft:soul_fire_flame",
            "count": 25,
            "speed": 0.4,
            "spread": {
              "x": 1.5,
              "y": 1.5,
              "z": 1.5
            }
          }
        ]
      }
    }
  },

  "badge": {
    "type": "origins:tooltip",
    "sprite": "origins:textures/gui/badge/active.png",
    "text": "When at or below 10%% HP, gain Strength II for 5 seconds. 60-second cooldown. Spite fuels your fading body."
  }
}